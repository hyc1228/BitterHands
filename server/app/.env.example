# When the web app is hosted on Vercel (or any origin) and the PartyKit room server is deployed
# separately, set the PartyKit *hostname* (no https://, no path). The client will connect to:
#   wss://<VITE_PARTYKIT_HOST>/party/<roomId>
#
# After `cd server && npx partykit deploy`, the CLI prints your project URL; use the host part only.
# Example:
# VITE_PARTYKIT_HOST=nocturne-zoo.yourname.partykit.dev
#
# Leave unset for local dev (Vite + PartyKit on the same host / proxy to 1999).

# Optional: main-scene iframe document (default: main-scene/zoo-scene.html). Built from repo `main scene/`
# via `server/scripts/sync-main-scene.mjs` when you run `npm run build:client`.
# VITE_MAIN_SCENE_PATH=main-scene/zoo-scene.html
