# Baked at `npm run build` (Vite production mode). WebSocket: wss://<host>/party/<room>
# If you change PartyKit deploy URL, update this and rebuild + `partykit deploy`.
VITE_PARTYKIT_HOST=nocturne-zoo.hyc1228.partykit.dev

# Operator key required to enter `/ob`. Anyone without this can't open the OB console.
# Change before deploying if needed; one-shot URL grant: `https://<host>/#/ob?key=<value>`.
VITE_OB_KEY=keeper-1228
