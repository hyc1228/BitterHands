.DS_Store

# Node
**/node_modules/
server/app/dist/
pitch/dist/
**/*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local Cursor session state (per-session debug logs, agent metadata).
.cursor/

# PartyKit local dev state
**/.partykit/

# mkcert / local HTTPS (see server README)
server/certs/

# Copied from repo `main scene/` for Vite `publicDir` (see server/scripts/sync-main-scene.mjs)
server/app/public/main-scene/
server/app/public/nz-scene.html
server/app/public/nz-scene.document
# `server/public/main-scene/**` is tracked so PartyKit deploy includes the iframe (SPA fallback
# was serving the React `index.html` for `/main-scene/*` when this folder was gitignored).

# Pitch / marketing artifacts copied into the publicDir by sync-main-scene.mjs.
# Source lives in `resource/` at the repo root; the synced copies are pure
# build outputs and shouldn't pollute the working tree.
server/app/public/resource/ScreenShot_*
server/app/public/resource/face-detect.*
server/public/resource/ScreenShot_*
server/public/resource/face-detect.*

# Optional local design notes (not part of the app build)
design-system/

# Local player avatars (Vite dev → server/public/avatars)
server/public/avatars/**
!server/public/avatars/.gitkeep

# itch.io HTML5 build output (see server/scripts/build-itch.mjs).
# Both the staged tree and the final zip are pure build artifacts; the
# zip is what you upload to itch.io's project page.
server/itch-build/
nocturne-zoo-itch.zip

# itch.io page assets (cover + screenshots) generated from pitch slides.
# Source images live in pitch/preview/ and resource/; the resized
# versions in itch-assets/ are deterministic build outputs you upload
# manually via the itch.io web UI.
itch-assets/*.png
itch-assets/*.jpg

